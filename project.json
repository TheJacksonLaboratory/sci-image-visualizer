{
  "name": "jax-image-visualization",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/jax-image-visualization/src",
  "prefix": "jax",
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:ng-packagr",
      "outputs": ["{workspaceRoot}/dist/libs/jax-image-visualization"],
      "options": {
        "project": "libs/jax-image-visualization/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/jax-image-visualization/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/jax-image-visualization/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": [
          "libs/jax-image-visualization/**/*.ts",
          "libs/jax-image-visualization/**/*.html"
        ]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/jax-image-visualization/jest.config.ts"
      }
    }
  },
  "tags": ["scope:visualization"]
}
